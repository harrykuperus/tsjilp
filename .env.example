# Copy to ".env" (do not commit .env) and fill in values.

# ── App / Security ──────────────────────────────────────
APP_SECRET=***
WEBHOOK_SECRET=""

# ── AI Providers ────────────────────────────────────────
# Leave blank to disable. Users can set their own keys in the app.
# A default key here enables trial credits for new users.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

GEMINI_API_KEY=""
ANTHROPIC_API_KEY=""

# ── Guest Trial Credits ─────────────────────────────────
# Number of free AI messages for unregistered visitors.
# Set to 0 to disable trial credits.
GUEST_TRIAL_LIMIT=10

# ── SMTP (email sending — optional) ─────────────────────
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="tls"
SMTP_USERNAME=""
SMTP_PASSWORD=""
SMTP_FROM_EMAIL=""
SMTP_FROM_NAME="Tsjilp"

# ── Stripe (donations — optional) ────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""

# ── OAuth (optional — for Google/Apple login) ───────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
APPLE_CLIENT_ID=""
APPLE_CLIENT_SECRET=""

# ── Feedback endpoint ───────────────────────────────────
FEEDBACK_TO_EMAIL=""
FEEDBACK_TO_NAME=""